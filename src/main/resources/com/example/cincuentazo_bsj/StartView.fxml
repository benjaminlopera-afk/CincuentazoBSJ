<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cincuentazo_bsj.controllers.StartController"
           styleClass="root-background"
           stylesheets="@../../../Styles.css"
           prefWidth="900.0" prefHeight="650.0">

    <VBox alignment="CENTER" spacing="22" maxWidth="640">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <Label text="♠ CINCUENTAZO ♥" styleClass="title-label"/>
        <Label text="No excedas la suma de 50 en la mesa. Sé el último en pie."
               styleClass="subtitle-label"/>

        <Button fx:id="rulesButton" text="¿CÓMO SE JUEGA?"
                onAction="#handleShowRules" styleClass="rules-button"/>

        <VBox spacing="22" alignment="CENTER" styleClass="selector-panel">
            <Label text="¿Contra cuántas máquinas quieres jugar?" styleClass="section-label"/>

            <HBox spacing="22" alignment="CENTER">
                <fx:define>
                    <ToggleGroup fx:id="machineCountGroup"/>
                </fx:define>

                <RadioButton fx:id="oneMachineOption" toggleGroup="$machineCountGroup" styleClass="player-card">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8" prefWidth="150" prefHeight="120">
                            <Label text="1" styleClass="player-card-number"/>
                            <Label text="Máquina" styleClass="player-card-label"/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <RadioButton fx:id="twoMachineOption" toggleGroup="$machineCountGroup" styleClass="player-card">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8" prefWidth="150" prefHeight="120">
                            <Label text="2" styleClass="player-card-number"/>
                            <Label text="Máquinas" styleClass="player-card-label"/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <RadioButton fx:id="threeMachineOption" toggleGroup="$machineCountGroup" styleClass="player-card">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8" prefWidth="150" prefHeight="120">
                            <Label text="3" styleClass="player-card-number"/>
                            <Label text="Máquinas" styleClass="player-card-label"/>
                        </VBox>
                    </graphic>
                </RadioButton>
            </HBox>
        </VBox>

        <Button fx:id="startButton" text="INICIAR JUEGO" disable="true"
                onAction="#handleStartGame" styleClass="start-button"/>
    </VBox>
</StackPane>
